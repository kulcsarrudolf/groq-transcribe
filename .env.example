# Copy this file to .env and fill in your key. The .env file is git-ignored.

# Required. Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Optional. Whisper model to use (default: whisper-large-v3).
# GROQ_WHISPER_MODEL=whisper-large-v3

# Optional. Default source language as an ISO-639-1 code (default: en).
# TRANSCRIBE_DEFAULT_LANGUAGE=en

# Optional. Groq upload limit in bytes; larger files are auto-compressed with
# ffmpeg before upload (default: 26214400, i.e. 25 MB).
# GROQ_MAX_UPLOAD_BYTES=26214400

# Optional. ffmpeg re-encode target for oversized audio.
# COMPRESS_SAMPLE_RATE=16000
# COMPRESS_BITRATE=48k
